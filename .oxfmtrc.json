{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"semi": false,
	"singleQuote": true,
	"ignorePatterns": [],
	"overrides": [
		{
			"files": ["*.yml"],
			"options": {
				"singleQuote": false
			}
		},
		{
			"files": ["**/package.json"],
			"options": {
				"useTabs": false,
				"tabWidth": 2
			}
		}
	]
}
